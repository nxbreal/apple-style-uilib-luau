function AppleUI:_createToggle(parent, config)
    config = config or {}
    local label    = config.Text or "Toggle"
    local default  = if config.Default ~= nil then config.Default else false
    local callback = config.Callback or function() end
    local order    = config.LayoutOrder or 999
    local toggled  = default

    local container = Util.create("Frame", {
        Name = "ToggleContainer",
        BackgroundColor3 = Tokens.BgTertiary,
        Size = UDim2.new(1, 0, 0, 38),
        LayoutOrder = order,
        ZIndex = 4,
        Parent = parent,
    })
    Util.addCorner(container, Tokens.CornerSmall)

    Util.create("TextLabel", {
        Name = "Label",
        Text = label,
        Font = Tokens.FontFamily,
        TextSize = Tokens.FontSizeBody,
        TextColor3 = Tokens.TextPrimary,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -70, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 5,
        Parent = container,
    })

    local track = Util.create("Frame", {
        Name = "Track",
        BackgroundColor3 = if toggled then Tokens.Accent else Tokens.BgHover,
        Size = UDim2.new(0, 42, 0, 22),
        Position = UDim2.new(1, -54, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        ZIndex = 5,
        Parent = container,
    })
    Util.addCorner(track, UDim.new(1, 0))

    local knob = Util.create("Frame", {
        Name = "Knob",
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Size = UDim2.new(0, 16, 0, 16),
        Position = if toggled then UDim2.new(1, -19, 0.5, 0) else UDim2.new(0, 3, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        ZIndex = 6,
        Parent = track,
    })
    Util.addCorner(knob, UDim.new(1, 0))

    local function updateVisual()
        if toggled then
            Util.quickTween(track, 0.3, { BackgroundColor3 = Tokens.Accent })
            Util.quickTween(knob, 0.3, { Position = UDim2.new(1, -19, 0.5, 0) })
        else
            Util.quickTween(track, 0.3, { BackgroundColor3 = Tokens.BgHover })
            Util.quickTween(knob, 0.3, { Position = UDim2.new(0, 3, 0.5, 0) })
        end
    end

    local clickBtn = Util.create("TextButton", {
        Name = "ClickArea",
        Text = "",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 7,
        Parent = container,
    })
    clickBtn.MouseButton1Click:Connect(function()
        toggled = not toggled
        updateVisual()
        pcall(callback, toggled)
    end)

    local api = {}
    function api:Set(v) toggled = v; updateVisual(); pcall(callback, toggled) end
    function api:Get() return toggled end
    return api
end

