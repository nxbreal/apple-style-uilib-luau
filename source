            updateColor()
        end
    end))
    table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then hueDrag = false end
    end))

    preview.MouseButton1Click:Connect(function()
        pickerOpen = not pickerOpen
        if pickerOpen then
            -- Position the panel near the preview button in absolute screen coords
            local absPos = preview.AbsolutePosition
            local absSize = preview.AbsoluteSize
            pickerPanel.Position = UDim2.new(0, absPos.X + absSize.X + 8, 0, absPos.Y - 60)
        end
        pickerPanel.Visible = pickerOpen
    end)

    local api = {}
    function api:Set(c) hue, sat, val = c:ToHSV(); updateColor() end
    function api:Get() return currentColor end
    return api
end

