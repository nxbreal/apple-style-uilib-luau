        Font = Tokens.FontLight,
        TextSize = Tokens.FontSizeSmall,
        TextColor3 = Tokens.TextSecondary,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -16, 0, 18),
        Position = UDim2.new(0, 12, 0, 30),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 101,
        Parent = toast,
    })

    Util.quickTween(toast, 0.4, { Position = UDim2.new(1, -290, 1, -70) })
    task.delay(duration, function()
        Util.quickTween(toast, 0.4, { Position = UDim2.new(1, -290, 1, 10) })
        task.delay(0.5, function() toast:Destroy() end)
    end)
end

---------------------------------------------------------------------
-- KEYBIND: Toggle visibility
---------------------------------------------------------------------
function AppleUI:BindToggle(keyCode)
    keyCode = keyCode or Enum.KeyCode.RightControl
    table.insert(self._connections, UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == keyCode then
            self._main.Visible = not self._main.Visible
        end
    end))
end

---------------------------------------------------------------------
-- RETURN MODULE
---------------------------------------------------------------------
return AppleUI
