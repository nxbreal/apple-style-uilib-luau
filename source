function AppleUI:_createDropdown(parent, config)
    config = config or {}
    local label    = config.Text or "Dropdown"
    local items    = config.Items or {"Option 1", "Option 2", "Option 3"}
    local default  = config.Default or items[1]
    local callback = config.Callback or function() end
    local order    = config.LayoutOrder or 999
    local isOpen   = false
    local selected = default

    local container = Util.create("Frame", {
        Name = "DropdownContainer",
        BackgroundColor3 = Tokens.BgTertiary,
        Size = UDim2.new(1, 0, 0, 38),
        ClipsDescendants = false,
        LayoutOrder = order,
        ZIndex = 10,
        Parent = parent,
    })
    Util.addCorner(container, Tokens.CornerSmall)

    Util.create("TextLabel", {
        Name = "Label",
        Text = label,
        Font = Tokens.FontFamily,
        TextSize = Tokens.FontSizeBody,
        TextColor3 = Tokens.TextPrimary,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.4, 0, 0, 38),
        Position = UDim2.new(0, 12, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 11,
        Parent = container,
    })

    local selectedBtn = Util.create("TextButton", {
        Name = "SelectedBtn",
        Text = selected .. "  ▾",
        Font = Tokens.FontFamily,
        TextSize = Tokens.FontSizeBody,
        TextColor3 = Tokens.TextSecondary,
        BackgroundColor3 = Tokens.BgPrimary,
        Size = UDim2.new(0.55, -12, 0, 26),
        Position = UDim2.new(0.45, 0, 0, 6),
        AutoButtonColor = false,
        ZIndex = 11,
        Parent = container,
    })
    Util.addCorner(selectedBtn, Tokens.CornerSmall)
    Util.addStroke(selectedBtn, Tokens.BorderLight, 1)

    local optionList = Util.create("Frame", {
        Name = "OptionList",
        BackgroundColor3 = Tokens.BgSecondary,
        Size = UDim2.new(0.55, -12, 0, #items * 28 + 8),
        Position = UDim2.new(0.45, 0, 0, 36),
        Visible = false,
        ClipsDescendants = true,
        ZIndex = 50,
        Parent = container,
    })
    Util.addCorner(optionList, Tokens.CornerSmall)
    Util.addStroke(optionList, Tokens.BorderLight, 1)
    Util.addPadding(optionList, 4, 4, 4, 4)
    Util.addListLayout(optionList, 2)

    local function makeOption(item, idx)
        local optBtn = Util.create("TextButton", {
            Name = "Opt_" .. item,
            Text = item,
            Font = Tokens.FontLight,
            TextSize = Tokens.FontSizeSmall,
            TextColor3 = Tokens.TextSecondary,
            BackgroundColor3 = Tokens.BgTertiary,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 26),
            AutoButtonColor = false,
            LayoutOrder = idx,
            ZIndex = 51,
            Parent = optionList,
        })
        Util.addCorner(optBtn, Tokens.CornerSmall)
        optBtn.MouseEnter:Connect(function()
            Util.quickTween(optBtn, 0.15, { BackgroundTransparency = 0.3, TextColor3 = Tokens.TextPrimary })
        end)
        optBtn.MouseLeave:Connect(function()
            Util.quickTween(optBtn, 0.15, { BackgroundTransparency = 1, TextColor3 = Tokens.TextSecondary })
        end)
        optBtn.MouseButton1Click:Connect(function()
            selected = item
            selectedBtn.Text = item .. "  ▾"
            isOpen = false
            optionList.Visible = false
            pcall(callback, item)
        end)
    end

    for i, item in ipairs(items) do
        makeOption(item, i)
    end

    selectedBtn.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        optionList.Visible = isOpen
    end)

    table.insert(self._connections, UserInputService.InputBegan:Connect(function(input)
        if isOpen and input.UserInputType == Enum.UserInputType.MouseButton1 then
            task.defer(function()
                local pos = input.Position
                local abs = optionList.AbsolutePosition
                local sz  = optionList.AbsoluteSize
                local bAbs = selectedBtn.AbsolutePosition
                local bSz  = selectedBtn.AbsoluteSize
                local inOpt = pos.X >= abs.X and pos.X <= abs.X + sz.X and pos.Y >= abs.Y and pos.Y <= abs.Y + sz.Y
                local inBtn = pos.X >= bAbs.X and pos.X <= bAbs.X + bSz.X and pos.Y >= bAbs.Y and pos.Y <= bAbs.Y + bSz.Y
                if not inOpt and not inBtn then
                    isOpen = false
                    optionList.Visible = false
                end
            end)
        end
    end))

    local api = {}
    function api:Set(v) selected = v; selectedBtn.Text = v .. "  ▾"; pcall(callback, v) end
    function api:Get() return selected end
    function api:Refresh(newItems)
        for _, c in ipairs(optionList:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end
        items = newItems
        optionList.Size = UDim2.new(0.55, -12, 0, #items * 28 + 8)
        for i, item in ipairs(items) do makeOption(item, i) end
    end
    return api
end

