-- SCREEN GUI SETUP
---------------------------------------------------------------------
function AppleUI.new(config: {[string]: any}?)
    config = config or {}
    local self = setmetatable({}, AppleUI)

    self._config = {
        Title       = config.Title or "Apple UI",
        Size        = config.Size or UDim2.new(0, 520, 0, 380),
        MinSize     = config.MinSize or Vector2.new(400, 300),
        Theme       = config.Theme or "Dark",
        LoadAnim    = if config.LoadAnim ~= nil then config.LoadAnim else true,
    }
    self._tabs       = {}
    self._activeTab  = nil
    self._connections = {}
    self._destroyed  = false

    -- ScreenGui
    self._screenGui = Util.create("ScreenGui", {
        Name = "AppleUILib",
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        Parent = Player:WaitForChild("PlayerGui"),
    })

    -- Main container
    self._main = Util.create("CanvasGroup", {
        Name = "MainWindow",
        BackgroundColor3 = Tokens.BgPrimary,
        Size = self._config.Size,
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ClipsDescendants = true,
        Parent = self._screenGui,
    })
    Util.addCorner(self._main, Tokens.CornerRadius)
    Util.addStroke(self._main, Tokens.Border, 1)
    Util.addShadow(self._main)

    -- Build internal layout
    self:_buildTopbar()
    self:_buildSidebar()
    self:_buildContentArea()

    -- Draggable
    Util.makeDraggable(self._topbar, self._main)

    -- Load-in animation
    if self._config.LoadAnim then
        self:_playLoadAnimation()
    end

    return self
end

