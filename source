---------------------------------------------------------------------
-- UTILITY HELPERS
---------------------------------------------------------------------
local Util = {}

function Util.create(className: string, props: {[string]: any}, children: {Instance}?)
    local inst = Instance.new(className)
    for k, v in pairs(props) do
        if k ~= "Parent" then
            (inst :: any)[k] = v
        end
    end
    if children then
        for _, child in ipairs(children) do
            child.Parent = inst
        end
    end
    if props.Parent then
        inst.Parent = props.Parent
    end
    return inst
end

function Util.tween(obj: Instance, tweenInfo: TweenInfo, goals: {[string]: any})
    local t = TweenService:Create(obj, tweenInfo, goals)
    t:Play()
    return t
end

function Util.quickTween(obj: Instance, duration: number, goals: {[string]: any})
    return Util.tween(obj, TweenInfo.new(duration, Tokens.TweenEasing, Enum.EasingDirection.Out), goals)
end

function Util.addCorner(parent: Instance, radius: UDim?): UICorner
    local corner = Instance.new("UICorner")
    corner.CornerRadius = radius or Tokens.CornerRadius
    corner.Parent = parent
    return corner
end

function Util.addStroke(parent: Instance, color: Color3?, thickness: number?): UIStroke
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Tokens.Border
    stroke.Thickness = thickness or 1
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = parent
    return stroke
end

function Util.addPadding(parent: Instance, top: number?, left: number?, bottom: number?, right: number?): UIPadding
    local pad = Instance.new("UIPadding")
    pad.PaddingTop    = UDim.new(0, top or 8)
    pad.PaddingLeft   = UDim.new(0, left or 8)
    pad.PaddingBottom = UDim.new(0, bottom or 8)
    pad.PaddingRight  = UDim.new(0, right or 8)
    pad.Parent = parent
    return pad
end

function Util.addShadow(parent: GuiObject)
    local shadow = Util.create("ImageLabel", {
        Name = "Shadow",
        BackgroundTransparency = 1,
        Image = "rbxassetid://5554236805",
        ImageColor3 = Color3.fromRGB(0, 0, 0),
        ImageTransparency = Tokens.ShadowTransparency,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(23, 23, 277, 277),
        Size = UDim2.new(1, 30, 1, 30),
        Position = UDim2.new(0, -15, 0, -15),
        ZIndex = parent.ZIndex - 1,
        Parent = parent,
    })
    return shadow
end

function Util.addListLayout(parent: Instance, padding: number?, direction: Enum.FillDirection?)
    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, padding or 6)
    layout.FillDirection = direction or Enum.FillDirection.Vertical
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = parent
    return layout
end

function Util.ripple(button: GuiObject, x: number, y: number)
    local circle = Util.create("Frame", {
        Name = "Ripple",
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.85,
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0, x, 0, y),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = button.ZIndex + 5,
        Parent = button,
    })
    Util.addCorner(circle, UDim.new(1, 0))
    local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.5
    Util.quickTween(circle, 0.45, {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        BackgroundTransparency = 1,
    })
    task.delay(0.5, function()
        circle:Destroy()
    end)
end

function Util.clamp01(v: number): number
    return math.clamp(v, 0, 1)
end

function Util.lerpColor(a: Color3, b: Color3, t: number): Color3
    t = Util.clamp01(t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

function Util.hexToColor3(hex: string): Color3
    hex = hex:gsub("#", "")
    return Color3.fromRGB(
        tonumber(hex:sub(1, 2), 16) or 0,
        tonumber(hex:sub(3, 4), 16) or 0,
        tonumber(hex:sub(5, 6), 16) or 0
    )
end

function Util.color3ToHex(c: Color3): string
    return string.format("#%02X%02X%02X",
        math.floor(c.R * 255 + 0.5),
        math.floor(c.G * 255 + 0.5),
        math.floor(c.B * 255 + 0.5)
    )
end

---------------------------------------------------------------------
-- DRAGGABLE MIXIN
---------------------------------------------------------------------
function Util.makeDraggable(topbar: GuiObject, mainFrame: GuiObject)
    local dragging = false
    local dragStart: Vector3
    local startPos: UDim2

    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            Util.quickTween(mainFrame, 0.22, {
                Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                ),
            })
        end
    end)
end

