function AppleUI:_createSlider(parent, config)
    config = config or {}
    local label    = config.Text or "Slider"
    local minVal   = config.Min or 0
    local maxVal   = config.Max or 100
    local default  = config.Default or minVal
    local callback = config.Callback or function() end
    local order    = config.LayoutOrder or 999
    local suffix   = config.Suffix or ""
    local value    = default

    local container = Util.create("Frame", {
        Name = "SliderContainer",
        BackgroundColor3 = Tokens.BgTertiary,
        Size = UDim2.new(1, 0, 0, 50),
        LayoutOrder = order,
        ZIndex = 4,
        Parent = parent,
    })
    Util.addCorner(container, Tokens.CornerSmall)

    Util.create("TextLabel", {
        Name = "Label",
        Text = label,
        Font = Tokens.FontFamily,
        TextSize = Tokens.FontSizeBody,
        TextColor3 = Tokens.TextPrimary,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.6, 0, 0, 20),
        Position = UDim2.new(0, 12, 0, 4),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 5,
        Parent = container,
    })

    local valLabel = Util.create("TextLabel", {
        Name = "Value",
        Text = tostring(math.floor(value)) .. suffix,
        Font = Tokens.FontLight,
        TextSize = Tokens.FontSizeSmall,
        TextColor3 = Tokens.TextSecondary,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.4, -12, 0, 20),
        Position = UDim2.new(0.6, 0, 0, 4),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 5,
        Parent = container,
    })

    local trackBg = Util.create("Frame", {
        Name = "TrackBg",
        BackgroundColor3 = Tokens.BgHover,
        Size = UDim2.new(1, -24, 0, 6),
        Position = UDim2.new(0, 12, 0, 34),
        ZIndex = 5,
        Parent = container,
    })
    Util.addCorner(trackBg, UDim.new(1, 0))

    local fillFrac = Util.clamp01((value - minVal) / (maxVal - minVal))

    local trackFill = Util.create("Frame", {
        Name = "TrackFill",
        BackgroundColor3 = Tokens.Accent,
        Size = UDim2.new(fillFrac, 0, 1, 0),
        ZIndex = 6,
        Parent = trackBg,
    })
    Util.addCorner(trackFill, UDim.new(1, 0))

    local knob = Util.create("Frame", {
        Name = "Knob",
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new(fillFrac, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = 7,
        Parent = trackBg,
    })
    Util.addCorner(knob, UDim.new(1, 0))

    local dragging = false

    local function updateSlider(inputPos)
        local trackAbsX = trackBg.AbsolutePosition.X
        local trackW    = trackBg.AbsoluteSize.X
        local rel = Util.clamp01((inputPos.X - trackAbsX) / trackW)
        value = math.floor(minVal + (maxVal - minVal) * rel + 0.5)
        valLabel.Text = tostring(value) .. suffix
        trackFill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, 0, 0.5, 0)
        pcall(callback, value)
    end

    local sliderBtn = Util.create("TextButton", {
        Name = "SliderClickArea",
        Text = "",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 20),
        Position = UDim2.new(0, 0, 0, 26),
        ZIndex = 8,
        Parent = container,
    })
    sliderBtn.MouseButton1Down:Connect(function() dragging = true end)

    table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input.Position)
        end
    end))
    table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end))

    local api = {}
    function api:Set(v)
        value = math.clamp(v, minVal, maxVal)
        local rel = Util.clamp01((value - minVal) / (maxVal - minVal))
        valLabel.Text = tostring(math.floor(value)) .. suffix
        trackFill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, 0, 0.5, 0)
        pcall(callback, value)
    end
    function api:Get() return value end
    return api
end

