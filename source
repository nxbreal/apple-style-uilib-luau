function AppleUI:_buildTopbar()
    self._topbar = Util.create("Frame", {
        Name = "Topbar",
        BackgroundColor3 = Tokens.BgSecondary,
        Size = UDim2.new(1, 0, 0, 38),
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = self._main,
    })
    -- Only round the TOP corners — use a clip frame trick to avoid overriding
    local topCornerClip = Util.create("Frame", {
        Name = "TopCornerClip",
        BackgroundColor3 = Tokens.BgSecondary,
        Size = UDim2.new(1, 0, 0, 20),
        Position = UDim2.new(0, 0, 1, -20),
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = self._topbar,
    })
    Util.addCorner(self._topbar, Tokens.CornerRadius)

    -- Bottom border line
    Util.create("Frame", {
        Name = "TopbarBorder",
        BackgroundColor3 = Tokens.Border,
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BorderSizePixel = 0,
        ZIndex = 6,
        Parent = self._topbar,
    })

    -- Title
    self._titleLabel = Util.create("TextLabel", {
        Name = "Title",
        Text = self._config.Title,
        Font = Tokens.FontBold,
        TextSize = Tokens.FontSizeTitle,
        TextColor3 = Tokens.TextPrimary,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -160, 1, 0),
        Position = UDim2.new(0.5, 0, 0, 0),
        AnchorPoint = Vector2.new(0.5, 0),
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 7,
        Parent = self._topbar,
    })

    -- Traffic-light buttons container
    local trafficContainer = Util.create("Frame", {
        Name = "TrafficLights",
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 70, 0, 20),
        Position = UDim2.new(0, 14, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        ZIndex = 8,
        Parent = self._topbar,
    })
    Util.addListLayout(trafficContainer, 8, Enum.FillDirection.Horizontal)

    -- Helper to build each traffic button
    local function makeTrafficBtn(name: string, color: Color3, order: number, callback: () -> ())
        local btn = Util.create("TextButton", {
            Name = name,
            Text = "",
            BackgroundColor3 = color,
            Size = UDim2.new(0, 14, 0, 14),
            AnchorPoint = Vector2.new(0, 0.5),
            AutoButtonColor = false,
            LayoutOrder = order,
            ZIndex = 9,
            Parent = trafficContainer,
        })
        Util.addCorner(btn, UDim.new(1, 0))

        -- Hover zoom effect: smooth slow grow
        btn.MouseEnter:Connect(function()
            Util.quickTween(btn, 0.35, { Size = UDim2.new(0, 18, 0, 18) })
        end)
        btn.MouseLeave:Connect(function()
            Util.quickTween(btn, 0.35, { Size = UDim2.new(0, 14, 0, 14) })
        end)
        btn.MouseButton1Click:Connect(callback)
        return btn
    end

    -- Close (red)
    self._btnClose = makeTrafficBtn("CloseBtn", Tokens.TrafficClose, 1, function()
        self:Destroy()
    end)

    -- Minimize (yellow)
    self._btnMinimize = makeTrafficBtn("MinimizeBtn", Tokens.TrafficMinimize, 2, function()
        self:Minimize()
    end)

    -- Maximize / fullscreen toggle (green)
    self._isMaximized = false
    self._btnMaximize = makeTrafficBtn("MaximizeBtn", Tokens.TrafficMaximize, 3, function()
        self:ToggleMaximize()
    end)
end

---------------------------------------------------------------------
-- MINIMIZE / MAXIMIZE
---------------------------------------------------------------------
function AppleUI:Minimize()
    if self._minimized then
        Util.quickTween(self._main, 0.35, {
            Size = self._restoreSize or self._config.Size,
        })
        self._minimized = false
    else
        self._restoreSize = self._main.Size
        Util.quickTween(self._main, 0.35, {
            Size = UDim2.new(self._main.Size.X.Scale, self._main.Size.X.Offset, 0, 38),
        })
        self._minimized = true
    end
end

function AppleUI:ToggleMaximize()
    if self._isMaximized then
        Util.quickTween(self._main, 0.4, {
            Size = self._restoreSizeMax or self._config.Size,
            Position = self._restorePos or UDim2.new(0.5, 0, 0.5, 0),
        })
        self._isMaximized = false
    else
        self._restoreSizeMax = self._main.Size
        self._restorePos = self._main.Position
        Util.quickTween(self._main, 0.4, {
            Size = UDim2.new(1, 0, 1, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
        })
        self._isMaximized = true
    end
end

