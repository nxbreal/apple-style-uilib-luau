        if svDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            sat = Util.clamp01((input.Position.X - svField.AbsolutePosition.X) / svField.AbsoluteSize.X)
            val = 1 - Util.clamp01((input.Position.Y - svField.AbsolutePosition.Y) / svField.AbsoluteSize.Y)
            updateColor()
        end
    end))
    table.insert(self._connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then svDrag = false end
