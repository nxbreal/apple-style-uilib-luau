    local hueCursor = Util.create("Frame", {
        Name = "HueCursor",
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        Size = UDim2.new(1, 4, 0, 4),
        Position = UDim2.new(0.5, 0, hue, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = 203,
        Parent = hueBar,
    })
    Util.addCorner(hueCursor, UDim.new(1, 0))

