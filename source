        BackgroundTransparency = 1,
        Size = UDim2.new(1, -16, 0, 20),
        Position = UDim2.new(0, 8, 1, -26),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 201,
        Parent = pickerPanel,
    })

