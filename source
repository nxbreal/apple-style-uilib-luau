---------------------------------------------------------------------
-- LOAD-IN ANIMATION (custom)
---------------------------------------------------------------------
function AppleUI:_playLoadAnimation()
    -- Start scaled down and transparent
    self._main.Size = UDim2.new(0, 0, 0, 0)
    self._main.BackgroundTransparency = 1
    self._topbar.BackgroundTransparency = 1
    self._sidebar.BackgroundTransparency = 1
    self._titleLabel.TextTransparency = 1

    -- Animate in
    task.defer(function()
        Util.quickTween(self._main, 0.6, {
            Size = self._config.Size,
            BackgroundTransparency = 0,
        })
        task.wait(0.15)
        Util.quickTween(self._topbar, 0.4, { BackgroundTransparency = 0 })
        Util.quickTween(self._sidebar, 0.4, { BackgroundTransparency = 0 })
        task.wait(0.1)
        Util.quickTween(self._titleLabel, 0.35, { TextTransparency = 0 })

        -- Fade in traffic buttons
        for _, child in ipairs(self._topbar:FindFirstChild("TrafficLights"):GetChildren()) do
            if child:IsA("TextButton") then
                child.BackgroundTransparency = 1
                Util.quickTween(child, 0.35, { BackgroundTransparency = 0 })
                task.wait(0.06)
            end
        end
    end)
end

---------------------------------------------------------------------
-- DESTROY
---------------------------------------------------------------------
function AppleUI:Destroy()
    if self._destroyed then return end
    self._destroyed = true

    -- Animate out
    Util.quickTween(self._main, 0.35, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
    })
    task.delay(0.4, function()
        for _, conn in ipairs(self._connections) do
            pcall(function() conn:Disconnect() end)
        end
        self._screenGui:Destroy()
    end)
end

---------------------------------------------------------------------
-- ADD TAB
---------------------------------------------------------------------
function AppleUI:AddTab(config)
    config = config or {}
    local tabName  = config.Name or ("Tab " .. tostring(#self._tabs + 1))
    local tabIcon  = config.Icon or ""
    local tabOrder = #self._tabs + 1

    local tabBtn = Util.create("TextButton", {
        Name = "TabBtn_" .. tabName,
        Text = "",
        BackgroundColor3 = Tokens.BgTertiary,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
        AutoButtonColor = false,
        LayoutOrder = tabOrder,
        ZIndex = 5,
        Parent = self._sidebarScroll,
    })
    Util.addCorner(tabBtn, Tokens.CornerSmall)

    local tabLabel = Util.create("TextLabel", {
        Name = "Label",
        Text = (tabIcon ~= "" and (tabIcon .. "  ") or "") .. tabName,
        Font = Tokens.FontFamily,
        TextSize = Tokens.FontSizeBody,
        TextColor3 = Tokens.TextSecondary,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 6,
        Parent = tabBtn,
    })

    local tabPage = Util.create("ScrollingFrame", {
        Name = "TabPage_" .. tabName,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Tokens.TextMuted,
        BorderSizePixel = 0,
        Visible = false,
        ZIndex = 3,
        Parent = self._content,
    })
    Util.addPadding(tabPage, 12, 16, 12, 16)
    local pageLayout = Util.addListLayout(tabPage, 8)

    local tabData = {
        Name = tabName, Button = tabBtn, Label = tabLabel,
        Page = tabPage, Layout = pageLayout, Order = tabOrder,
    }
    table.insert(self._tabs, tabData)

    tabBtn.MouseEnter:Connect(function()
        if self._activeTab ~= tabData then
            Util.quickTween(tabBtn, 0.2, { BackgroundTransparency = 0.5 })
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if self._activeTab ~= tabData then
            Util.quickTween(tabBtn, 0.2, { BackgroundTransparency = 1 })
        end
    end)
    tabBtn.MouseButton1Click:Connect(function()
        self:_switchTab(tabData)
    end)

    if #self._tabs == 1 then
        self:_switchTab(tabData)
    end

    local TabAPI = {}
    TabAPI._page = tabPage
    TabAPI._layout = pageLayout
    TabAPI._lib = self

    function TabAPI:AddButton(cfg) return self._lib:_createButton(self._page, cfg) end
    function TabAPI:AddToggle(cfg) return self._lib:_createToggle(self._page, cfg) end
    function TabAPI:AddLabel(cfg) return self._lib:_createLabel(self._page, cfg) end
    function TabAPI:AddText(cfg) return self._lib:_createTextInput(self._page, cfg) end
    function TabAPI:AddDropdown(cfg) return self._lib:_createDropdown(self._page, cfg) end
    function TabAPI:AddSlider(cfg) return self._lib:_createSlider(self._page, cfg) end
    function TabAPI:AddColorpicker(cfg) return self._lib:_createColorpicker(self._page, cfg) end
    function TabAPI:AddSeparator() return self._lib:_createSeparator(self._page) end

    return TabAPI
end

---------------------------------------------------------------------
-- SWITCH TAB
---------------------------------------------------------------------
function AppleUI:_switchTab(tabData)
    if self._activeTab then
        local old = self._activeTab
        Util.quickTween(old.Button, 0.25, { BackgroundTransparency = 1 })
        Util.quickTween(old.Label, 0.2, { TextColor3 = Tokens.TextSecondary })
        old.Page.Visible = false
    end
    self._activeTab = tabData
    Util.quickTween(tabData.Button, 0.25, { BackgroundTransparency = 0.15 })
    Util.quickTween(tabData.Label, 0.2, { TextColor3 = Tokens.TextPrimary })
    tabData.Page.Visible = true
end

---------------------------------------------------------------------
-- COMPONENT: BUTTON
---------------------------------------------------------------------
function AppleUI:_createButton(parent, config)
    config = config or {}
    local btnText  = config.Text or "Button"
    local callback = config.Callback or function() end
    local order    = config.LayoutOrder or 999

    local container = Util.create("Frame", {
        Name = "ButtonContainer",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 36),
        LayoutOrder = order,
        ZIndex = 4,
        Parent = parent,
    })

    local btn = Util.create("TextButton", {
        Name = "Button",
        Text = btnText,
        Font = Tokens.FontFamily,
        TextSize = Tokens.FontSizeBody,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        BackgroundColor3 = Tokens.Accent,
        Size = UDim2.new(1, 0, 1, 0),
        AutoButtonColor = false,
        ClipsDescendants = true,
        ZIndex = 5,
        Parent = container,
    })
    Util.addCorner(btn, Tokens.CornerSmall)

    btn.MouseEnter:Connect(function()
        Util.quickTween(btn, 0.2, { BackgroundColor3 = Tokens.AccentHover })
    end)
    btn.MouseLeave:Connect(function()
        Util.quickTween(btn, 0.2, { BackgroundColor3 = Tokens.Accent })
    end)
    btn.MouseButton1Click:Connect(function()
        Util.ripple(btn, Mouse.X - btn.AbsolutePosition.X, Mouse.Y - btn.AbsolutePosition.Y)
        pcall(callback)
    end)

    local api = {}
    function api:SetText(t) btn.Text = t end
    return api
end

